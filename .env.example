# ============================================================================
# Reacher Email Verification stack — environment
# Copy to .env and edit:  cp .env.example .env
# ============================================================================

# Compose project / stack name (prefixes container + network names).
COMPOSE_PROJECT_NAME=reacher

# ── Image ───────────────────────────────────────────────────────────────────
# Public queue-capable image (default). To run your own build compiled from
# svnix-solutions/check-if-email-exists, set this to e.g.
# ghcr.io/<owner>/reacher-backend:latest
REACHER_IMAGE=reacherhq/backend:latest

# ── Reacher backend ──────────────────────────────────────────────────────────
REACHER_BACKEND_NAME=reacher-backend

# Host port the API is published on (http://<host>:8080) for local/direct
# access. When exposing ONLY through the Cloudflare Tunnel you can drop the
# `ports:` mapping in compose.yaml and keep the API network-internal. Required
# to be removed when scaling REACHER_REPLICAS > 1.
REACHER_HTTP_PORT=8080

# EHLO/HELO name and MAIL FROM address for the SMTP conversation. For accurate
# deliverability, use a domain whose reverse-DNS (PTR) resolves to this host's
# public IP.
REACHER_HELLO_NAME=mail.example.com
REACHER_FROM_EMAIL=verify@example.com

# Shared secret required in the `x-reacher-secret` request header. STRONGLY
# recommended if the API is reachable from outside. Generate: openssl rand -hex 32
REACHER_HEADER_SECRET=

# Worker concurrency (emails verified in parallel by one instance).
REACHER_CONCURRENCY=5

# Number of backend/worker replicas. If > 1, remove the host port mapping in
# compose.yaml and reach the API via the cloudflared network (a published port
# can't be shared by multiple replicas).
REACHER_REPLICAS=1

# Per-worker throttle for /v1/* endpoints (protects IPs from being blocked).
REACHER_MAX_RPM=60
REACHER_MAX_RPD=10000

RUST_LOG=reacher=info

# ── SOCKS5 proxy (optional) ──────────────────────────────────────────────────
# Only used when you enable the compose.proxy.yaml overlay (see README). Needed
# if your host's outbound TCP port 25 is blocked (common on clouds).
# See https://proxy25.com. Without the overlay, no proxy section is configured
# and these are ignored — verification runs from this host's own IP.
#
# REACHER_PROXY_HOST and _PORT are required to enable the overlay. Set USERNAME
# and _PASSWORD (and uncomment their lines in compose.proxy.yaml) only if the
# proxy needs authentication.
REACHER_PROXY_HOST=
REACHER_PROXY_PORT=
REACHER_PROXY_USERNAME=
REACHER_PROXY_PASSWORD=

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_MGMT_PORT=15672
RABBITMQ_IMAGE_TAG=4.0-management

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=reacher
POSTGRES_PASSWORD=reacher
POSTGRES_DB=reacher_db
POSTGRES_IMAGE_TAG=16-alpine

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# External Docker network shared with the cloudflared connector (from the
# cloudflare_tunnel_build stack). Must match CLOUDFLARE_TUNNEL_NETWORK there.
# Create once:  docker network create cloudflared
CLOUDFLARE_TUNNEL_NETWORK=cloudflared
# In the Cloudflare Zero Trust dashboard, add a Public hostname for your tunnel
# pointing at:  http://<COMPOSE_PROJECT_NAME>-backend:8080  (e.g. reacher-backend:8080)
